# ─── AgriSMES Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# ── Supabase (required) ───────────────────────────────────────────────────────
# Project URL and anon/publishable key — safe to expose in the browser bundle.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>
VITE_SUPABASE_ANON_KEY=<anon-key>        # same value as PUBLISHABLE_KEY — some components use this name

# Service role key — server-side ONLY (Vercel env, never VITE_ prefix).
# Used by api/ handlers via getSupabaseAdmin().
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Anthropic (required for /api/anthropic-analyse) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (required for /api/notify-pro) ─────────────────────────────────────
RESEND_API_KEY=re_...
AGRISMES_FROM_EMAIL=noreply@yourdomain.com

# ── Polar (required for subscription webhooks and portal) ─────────────────────
POLAR_WEBHOOK_SECRET=<webhook-secret-from-polar-dashboard>
POLAR_CUSTOMER_PORTAL_URL=https://polar.sh/...
POLAR_PORTAL_URL=https://polar.sh/...      # alias used in some api handlers

# ── Paddle (required for Paddle billing integration) ──────────────────────────
VITE_PADDLE_CLIENT_TOKEN=<paddle-client-token>

# ── Error Monitoring — Sentry (optional) ──────────────────────────────────────
# The app works fully without these. Add them when you have a Sentry project.
#
# How to set up:
#   1. Create project at https://sentry.io → Platform: React
#   2. Copy the DSN from Project Settings → Client Keys
#   3. Add VITE_SENTRY_DSN here and in Vercel environment variables
#   4. Install SDK: npm install @sentry/react
#   5. In src/main.tsx, add:
#
#        import * as Sentry from '@sentry/react';
#        if (import.meta.env.VITE_SENTRY_DSN) {
#          Sentry.init({
#            dsn: import.meta.env.VITE_SENTRY_DSN,
#            environment: import.meta.env.MODE,
#          });
#        }
#
# For server-side (api/ handlers), use @sentry/node with SENTRY_DSN (no VITE_ prefix).
VITE_SENTRY_DSN=
# SENTRY_DSN=               # server-side handlers (api/)
# SENTRY_AUTH_TOKEN=        # only needed for source map uploads in CI — do not set until ready

# ── Google / Analytics (optional) ─────────────────────────────────────────────
VITE_GEMINI_API_KEY=

# ── Vercel (set automatically by Vercel, do not set manually) ─────────────────
# VERCEL_ENV=production|preview|development
# VERCEL_URL=<deployment-url>
