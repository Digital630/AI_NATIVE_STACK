# ─── TradeDoc Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# ── Supabase (required) ───────────────────────────────────────────────────────
# Project URL and anon key — safe to expose in the browser bundle.
# These are used by src/lib/supabase.ts and src/lib/tradedoc.ts.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ── OTP / Email Auth troubleshooting checklist ────────────────────────────────
# If users see "Network error. Check your connection." on OTP verify:
#   1. Confirm VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are set in Vercel
#      (Project → Settings → Environment Variables → Production)
#   2. Confirm the values match the PROJECT shown in your Supabase dashboard
#      (Settings → API → Project URL and anon/public key)
#   3. In Supabase: Authentication → Providers → Email → confirm "Enable Email provider" is ON
#   4. In Supabase: Authentication → Rate Limits — OTP default is 5/hour per address;
#      raise if your users hit it
#   5. In Supabase: Authentication → URL Configuration → add your Vercel domain
#      to "Site URL" and "Redirect URLs" (e.g. https://tradedoc.vercel.app)

# ── Error Monitoring — Sentry (optional) ──────────────────────────────────────
# The app works fully without these. Add them when you have a Sentry project.
#
# How to set up:
#   1. Create project at https://sentry.io → Platform: React
#   2. Copy the DSN from Project Settings → Client Keys
#   3. Add VITE_SENTRY_DSN here and in Vercel environment variables
#   4. Install SDK: npm install @sentry/react
#   5. In src/main.tsx, add before createRoot():
#
#        import * as Sentry from '@sentry/react';
#        if (import.meta.env.VITE_SENTRY_DSN) {
#          Sentry.init({
#            dsn: import.meta.env.VITE_SENTRY_DSN,
#            environment: import.meta.env.MODE,
#            tracesSampleRate: 0.2,
#          });
#        }
#
VITE_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=        # only needed for source map uploads in CI — do not set until ready

# ── Supabase (server-side — set in Vercel, NEVER use VITE_ prefix) ───────────
# Used by api/tradedoc.js and api/polar-webhook.js (Vercel Serverless Functions).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Anthropic (required for AI features in api/tradedoc.js) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (required for transactional email) ─────────────────────────────────
RESEND_API_KEY=re_...
TRADEDOC_FROM_EMAIL=noreply@yourdomain.com
TRADEDOC_FALLBACK_FROM_EMAIL=noreply@yourdomain.com

# ── Polar (required for subscription billing) ─────────────────────────────────
POLAR_WEBHOOK_SECRET=<polar-webhook-secret>
TRADEDOC_POLAR_WEBHOOK_SECRET=<polar-webhook-secret>
TRADEDOC_POLAR_PORTAL_URL=https://polar.sh/yourdomain/portal

# ── Cron job authentication ────────────────────────────────────────────────────
CRON_SECRET=<random-secret>

# ── Payment webhook (legacy/generic) ─────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=<payment-webhook-secret>

# ── Vercel (set automatically by Vercel, do not set manually) ─────────────────
# VERCEL_ENV=production|preview|development
# VERCEL_URL=<deployment-url>
