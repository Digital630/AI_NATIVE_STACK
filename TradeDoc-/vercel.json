{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/tradedoc.js": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/tradedoc?action=daily_job",
      "schedule": "0 6 * * *"
    }
  ]
}
